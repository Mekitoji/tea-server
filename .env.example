PORT=3000

ADMIN_EMAIL=mktji.job@gmail.com
ADMIN_NAME=mktji
ADMIN_PASSWORD=teapassword

DATABASE_URL="postgresql://teamaster:teapassword@localhost:5432/tea_master"

PG_APPLICATION_NAME=tea-server-api
PG_POOL_MIN=1
PG_POOL_MAX=10
PG_POOL_IDLE_TIMEOUT_MS=0
PG_POOL_CONNECTION_TIMEOUT_MS=5000
PG_POOL_KEEP_ALIVE=true

OTEL_ENABLED=false
OTEL_SERVICE_NAME=tea-server
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
DOCKER_OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_TRACE_HEALTHCHECKS=false
OTEL_TRACE_METRICS=false
OTEL_PG_ENHANCED_DATABASE_REPORTING=false
JAEGER_UI_PORT=16686
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
CADVISOR_PORT=8080
DOCKER_SOCKET_PATH=/var/run/docker.sock
METRICS_ENABLED=true
METRICS_HTTP_HEALTHCHECKS=false
METRICS_EVENT_LOOP_RESOLUTION_MS=20
LOG_HTTP_METRICS=false

JWT_SECRET=long-random-secret
AUTH_ACCESS_MINUTES=15
AUTH_REFRESH_DAYS=30

DEVICE_PAIRING_VERIFICATION_URL=http://localhost:5173/devices/register
DEVICE_PAIRING_EXPIRES_MINUTES=10
DEVICE_PAIRING_POLL_INTERVAL_SEC=3
DEVICE_PAIRING_CODE_PEPPER=long-random-pairing-code-pepper
DEVICE_PAIRING_MAX_ACTIVE_PER_DEVICE=3
DEVICE_PAIRING_ACTIVE_WINDOW_MINUTES=15
